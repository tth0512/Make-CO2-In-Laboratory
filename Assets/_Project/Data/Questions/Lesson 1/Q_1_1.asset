  m_Script: {fileID: 11500000, guid: bf49d84cf156cd94b8dcda3db3afe5be, type: 3}
  m_Name: Q_1_1
  m_EditorClassIdentifier: Assembly-CSharp::Question
  questionID: question1.1
  questionText: 'The reaction between hydrogen and oxygen to form water is described
    as follows:

    Hydrogen+Oxygen --> Water

    The reactants are: '
  answers:
  - 'Hydrogen, water  '
  - 'Hydrogen, oxygen '
  - Oxygen, water
  - Water
  correctIndex: 1
  explanation: 'The initial substances that are transformed in a reaction are called
    reactants. Therefore, hydrogen and oxygen are the reactants.

'
