  m_Script: {fileID: 11500000, guid: 4da322fee81a473299d99dc0e4125745, type: 3}
  m_Name: Q_6_1
  m_EditorClassIdentifier: Assembly-CSharp::Question
  questionText: 'When the reaction yield is less than 100%: '
  answers:
  - The actual amount of reactant used is less than the theoretical amount.
  - The actual amount of product obtained is greater than the theoretical amount.
  - 'The actual amount of product obtained is less than the theoretical amount. '
  - 'The actual amount of product obtained is greater than or equal to the theoretical
    amount. '
  correctIndex: 2
  explanation: 'Explanation:

    When the reaction efficiency is less than 100%,
    the actual amount of product obtained will be less than the amount calculated
    in the chemical equation.'
