  m_Script: {fileID: 11500000, guid: bf49d84cf156cd94b8dcda3db3afe5be, type: 3}
  m_Name: Q_6_1
  m_EditorClassIdentifier: Assembly-CSharp::Question
  questionID: question4.1
  questionText: 'An iron sheet weighing 28g is left in the air; it reacts with oxygen
    to form rust. After some time, the sheet is weighed again, and the mass is 31.2g.
    The mass of oxygen that reacted is:

'
  answers:
  - '3.2 g '
  - 1.6 g
  - 6.4 g
  - 24.8 g
  correctIndex: 0
  explanation: "According to the Law of Conservation of Mass: Initial mass of iron+Mass
    of reacted oxygen=Final mass of iron Mass of oxygen=31.2\u221228=3.2 (grams)\n\n"
